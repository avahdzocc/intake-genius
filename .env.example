# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Google Calendar
# Point to a service account JSON key (with domain-wide delegation)
# OR an OAuth credentials.json. See docs/google-calendar-setup.md
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials/google_calendar.json

# Asana
# Personal Access Token: https://app.asana.com/0/developer-console
ASANA_ACCESS_TOKEN=...
# Workspace GID: GET https://app.asana.com/api/1.0/workspaces
ASANA_WORKSPACE_GID=...
# "New Intakes" project GID
ASANA_PROJECT_GID=...
# Managing partner user GID (for conflict escalation)
ASANA_MANAGING_PARTNER_GID=...

# Database
DATABASE_URL=./intake_genius.db

# Firm
FIRM_NAME=Your Law Firm
INTAKE_EMAIL=intake@yourfirm.com
MANAGING_PARTNER_EMAIL=partner@yourfirm.com

# App
BASE_URL=http://localhost:8000
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
CONSULTATION_DURATION_MINUTES=60
TIMEZONE=America/Los_Angeles
